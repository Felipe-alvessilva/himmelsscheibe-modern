<?xml version="1.0" encoding="utf-8"?>
<!--
    Permite tráfego HTTP (cleartext) — necessário para o Unity antigo fazer download de assets.
    Em uma versão futura, restringir apenas aos domínios necessários.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
